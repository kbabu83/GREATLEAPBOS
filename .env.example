APP_NAME="Great Leap App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8000

# Multi-tenant central domain
CENTRAL_DOMAIN=greatlap.local

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Central database (tenants, domains, super-admin users)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=greatleap_central
DB_USERNAME=root
DB_PASSWORD=

# Tenants get their own databases prefixed with tenant_
TENANCY_DB_PREFIX=tenant_

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@greatleap.app"
MAIL_FROM_NAME="${APP_NAME}"

# Amazon SES Configuration (for production email sending)
# Change MAIL_MAILER to 'ses' to use Amazon SES instead of SMTP
# MAIL_MAILER=ses
# MAIL_SES_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Razorpay Payment Gateway Configuration
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
RAZORPAY_CURRENCY=INR
RAZORPAY_TIMEOUT=30
RAZORPAY_TEST_MODE=true
RAZORPAY_WEBHOOK_ENABLED=true
RAZORPAY_WEBHOOK_URL=/webhooks/razorpay

VITE_APP_NAME="${APP_NAME}"
VITE_CENTRAL_DOMAIN="${CENTRAL_DOMAIN}"
